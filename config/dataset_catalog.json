      "layer": "published",
      "description": "Canonical platform artifact combining semantic metrics, quality report, governance checks, trend history, and GenAI outputs.",
      "grain": "one snapshot per pipeline run",
      "owner": "samuelmaia-analytics",
      "refresh_mode": "pipeline_run",
      "contains_personal_data": false
    },
    {
      "dataset": "portfolio_platform_db",
      "path": "data/warehouse/portfolio_platform.db",
      "layer": "warehouse",
      "description": "SQLite analytical surface used for SQL assets, dbt-like models, and downstream validation.",
      "grain": "mixed analytical tables",
      "owner": "samuelmaia-analytics",
      "refresh_mode": "pipeline_run",
      "contains_personal_data": false
    }
  ]
