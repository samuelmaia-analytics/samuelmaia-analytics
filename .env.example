PORTFOLIO_ENV=dev
PORTFOLIO_LOG_LEVEL=INFO
PORTFOLIO_DATA_DIR=data
PORTFOLIO_ARTIFACTS_DIR=data/processed
PORTFOLIO_OBSERVABILITY_DIR=data/observability
PORTFOLIO_GENAI_PROVIDER=local-template
PORTFOLIO_GENAI_MODEL=gpt-portfolio-analyst
PORTFOLIO_GENAI_BASE_URL=
PORTFOLIO_GENAI_API_KEY=
PORTFOLIO_GENAI_TIMEOUT_SECONDS=10
PORTFOLIO_GENAI_MAX_RETRIES=2
PORTFOLIO_WAREHOUSE_PATH=data/warehouse/portfolio_platform.db
PORTFOLIO_SERVICE_API_KEYS=portfolio-demo-key
PORTFOLIO_SERVICE_API_KEY_SCOPES=portfolio-demo-key:snapshot,metrics,insights,repositories,admin
PORTFOLIO_SERVICE_RATE_LIMIT=30
PORTFOLIO_JWT_ENABLED=false
PORTFOLIO_JWT_SECRET=replace-with-a-32-char-minimum-secret
PORTFOLIO_JWT_ISSUER=samuelmaia-analytics
PORTFOLIO_JWT_AUDIENCE=portfolio-platform
PORTFOLIO_CHANGE_WATCH_THRESHOLD=1.0
PORTFOLIO_CHANGE_MATERIAL_THRESHOLD=3.0
PORTFOLIO_CHANGE_CRITICAL_THRESHOLD=5.0
